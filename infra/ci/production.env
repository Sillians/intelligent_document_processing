# CI-only production-shaped environment.
# These values are intentionally fake but high-entropy enough to exercise
# production preflight and Compose rendering. Do not deploy with this file.
IDP_ENV_FILE=infra/ci/production.env
ENVIRONMENT=production
PUBLIC_BASE_URL=https://idp-ci.internal
INFRASTRUCTURE_PROFILE=dedicated-persistent

INGESTION_KEYS_ROTATED_AT=2026-07-01T00:00:00Z
DATABASE_CREDENTIALS_ROTATED_AT=2026-07-01T00:00:00Z
CREDENTIAL_MAX_AGE_DAYS=3650
RAW_ARTIFACT_RETENTION_DAYS=30
DERIVED_ARTIFACT_RETENTION_DAYS=90
AUDIT_RETENTION_DAYS=365
BACKUP_RETENTION_DAYS=30
BACKUP_ENCRYPTION_ENABLED=true
BACKUP_ENCRYPTION_KEY=ci-backup-encryption-key-32-characters

POSTGRES_USER=idp
POSTGRES_PASSWORD=ci-postgres-password-32-characters

S3_ACCESS_KEY=ci-s3-access-key-32-characters
S3_SECRET_KEY=ci-s3-secret-key-32-characters
AWS_ACCESS_KEY_ID=ci-aws-access-key-32-characters
AWS_SECRET_ACCESS_KEY=ci-aws-secret-key-32-characters

GATEWAY_HTTP_BIND=127.0.0.1
GATEWAY_HTTP_HOST_PORT=8081
GATEWAY_HTTPS_BIND=0.0.0.0
GATEWAY_HTTPS_HOST_PORT=443
INGESTION_BIND=127.0.0.1

INGESTION_REQUIRE_AUTH=true
INGESTION_API_KEYS=ci-ingestion-api-key-32-chars:default
OCR_FORCE_FALLBACK=false
OCR_BACKEND=tesseract
ORCHESTRATOR_ENABLE_OCR_NETWORK_FALLBACK=false

LABEL_STUDIO_USERNAME=ci-reviewer
LABEL_STUDIO_PASSWORD=ci-label-studio-password-32chars
LABEL_STUDIO_TOKEN=ci-label-studio-token-32-characters
LABEL_STUDIO_DISABLE_SIGNUP_WITHOUT_LINK=true
LABEL_STUDIO_ENABLE_LEGACY_API_TOKEN=false
LABEL_STUDIO_AUTH_SCHEME=pat
REVIEW_FALLBACK_TO_LOCAL_QUEUE=false

GRAFANA_ADMIN_USER=idp-admin
GRAFANA_ADMIN_PASSWORD=ci-grafana-password-32characters

ALERT_EMAIL_FROM=alerts@idp-ci.internal
ALERT_EMAIL_TO=ops@idp-ci.internal
ALERT_EMAIL_HOST=smtp.idp-ci.internal
ALERT_EMAIL_PORT=587
ALERT_EMAIL_USERNAME=alerts@idp-ci.internal
ALERT_EMAIL_PASSWORD=ci-alert-email-password-32chars

DELIVERY_WEBHOOK_URL=
DELIVERY_WEBHOOK_SECRET=ci-delivery-webhook-secret-32
DELIVERY_WEBHOOK_REQUIRE_SIGNATURE=true
DELIVERY_ALLOW_REQUEST_WEBHOOK_URL=false
DELIVERY_WEBHOOK_ALLOWED_HOSTS=

EXTRACTION_ENABLE_VLM_FALLBACK=false
VLLM_API_KEY=ci-vllm-api-key-32-characters
