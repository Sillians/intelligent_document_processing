# Add these production-shaped controls to the GitHub STAGING_ENV_FILE secret.
# Replace every example secret and update rotation timestamps when rotation completes.
ENVIRONMENT=staging
PUBLIC_BASE_URL=https://staging-idp.your-domain.example
INFRASTRUCTURE_PROFILE=staging-persistent

# Two independently scoped keys are required by the tenant-isolation drill.
INGESTION_API_KEYS=replace-primary-key-at-least-32-characters:default,replace-isolation-key-at-least-32-characters:isolation-test
INGESTION_KEYS_ROTATED_AT=2026-07-03T00:00:00Z
DATABASE_CREDENTIALS_ROTATED_AT=2026-07-03T00:00:00Z
CREDENTIAL_MAX_AGE_DAYS=90

RAW_ARTIFACT_RETENTION_DAYS=30
DERIVED_ARTIFACT_RETENTION_DAYS=90
AUDIT_RETENTION_DAYS=365
BACKUP_RETENTION_DAYS=30
BACKUP_ENCRYPTION_ENABLED=true
BACKUP_ENCRYPTION_KEY=replace-with-independent-32-character-backup-key

OCR_BACKEND=tesseract
OCR_FORCE_FALLBACK=false
