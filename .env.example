# Core
POSTGRES_USER=idp
POSTGRES_PASSWORD=idp_password
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Buckets / Object storage (SeaweedFS S3-compatible API)
S3_ENDPOINT=seaweedfs:8333
S3_ACCESS_KEY=idpadmin
S3_SECRET_KEY=idpsecret123
S3_SECURE=false

# Backward-compatible aliases (optional)
MINIO_ENDPOINT=seaweedfs:8333
MINIO_ACCESS_KEY=idpadmin
MINIO_SECRET_KEY=idpsecret123
MINIO_SECURE=false
RAW_BUCKET=raw-documents
PREPROCESSED_BUCKET=preprocessed-documents
OCR_BUCKET=ocr-artifacts
LAYOUT_BUCKET=layout-artifacts
EXTRACTION_BUCKET=extraction-artifacts
DELIVERY_BUCKET=delivery-artifacts
MLFLOW_BUCKET=mlflow-artifacts

# Preprocess worker
PREPROCESS_MAX_DIMENSION=2200
PREPROCESS_DENOISE_H=12
PREPROCESS_THRESHOLD_BLOCK_SIZE=35
PREPROCESS_THRESHOLD_C=11
PREPROCESS_ENABLE_CLAHE=true
PREPROCESS_CLAHE_CLIP_LIMIT=2.0
PREPROCESS_CLAHE_TILE_GRID_SIZE=8
PREPROCESS_ENABLE_DESKEW=true
PREPROCESS_ENABLE_THRESHOLD=true
PREPROCESS_MEDIAN_BLUR_KERNEL=3
PREPROCESS_DESKEW_MIN_FOREGROUND_PIXELS=64
PREPROCESS_DESKEW_MAX_ANGLE=15.0
PREPROCESS_REQUEST_TIMEOUT_SECONDS=60
PREPROCESS_MAX_INFLIGHT_REQUESTS=4

# Layout service
LAYOUT_MODEL_CONFIG=lp://PubLayNet/faster_rcnn_R_50_FPN_3x/config
LAYOUT_MODEL_SCORE_THRESHOLD=0.5
LAYOUT_MIN_BLOCK_SCORE=0.35
LAYOUT_MIN_TOKEN_OVERLAP=0.1
LAYOUT_LINE_GROUP_Y_TOLERANCE=18
LAYOUT_REQUEST_TIMEOUT_SECONDS=90
LAYOUT_MAX_INFLIGHT_REQUESTS=2

# Classifier router service
CLASSIFIER_AUTO_ROUTE_THRESHOLD=0.68
CLASSIFIER_MIN_TEXT_CHARS=12
CLASSIFIER_REQUEST_TIMEOUT_SECONDS=15
CLASSIFIER_MAX_INFLIGHT_REQUESTS=8
CLASSIFIER_PERSIST_DECISION=true

# Extraction service
EXTRACTION_REQUEST_TIMEOUT_SECONDS=90
EXTRACTION_MAX_INFLIGHT_REQUESTS=4
EXTRACTION_ENABLE_VLM_FALLBACK=false
EXTRACTION_VLM_TIMEOUT_SECONDS=60
EXTRACTION_PROMPT_MAX_CHARS=8000

# Validation service
VALIDATION_BUCKET=validation-artifacts
VALIDATION_PROFILE=default
VALIDATION_POLICY_VERSION=2026-06-03
VALIDATION_REQUEST_TIMEOUT_SECONDS=30
VALIDATION_MAX_INFLIGHT_REQUESTS=16
VALIDATION_MIN_FIELD_CONFIDENCE=0.60
VALIDATION_AUTO_REJECT_THRESHOLD=0.25
VALIDATION_PERSIST_DECISION=true

# Temporal
TEMPORAL_ADDRESS=temporal:7233
TEMPORAL_NAMESPACE=default
TEMPORAL_TASK_QUEUE=idp-pipeline
ORCHESTRATOR_HTTP_TIMEOUT_SECONDS=300
ORCHESTRATOR_HTTP_CONNECT_TIMEOUT_SECONDS=10
ORCHESTRATOR_ENABLE_OCR_NETWORK_FALLBACK=true
TEMPORAL_WORKER_IDENTITY=
TEMPORAL_WORKER_MAX_CACHED_WORKFLOWS=1000
TEMPORAL_WORKER_MAX_CONCURRENT_WORKFLOW_TASKS=100
TEMPORAL_WORKER_MAX_CONCURRENT_ACTIVITIES=200
TEMPORAL_WORKER_GRACEFUL_SHUTDOWN_SECONDS=15

# Ingestion service controls
INGESTION_MAX_UPLOAD_SIZE_MB=25
INGESTION_ALLOWED_MIME_TYPES=application/pdf,image/png,image/jpeg,image/tiff,image/bmp,image/webp
INGESTION_ALLOWED_EXTENSIONS=pdf,png,jpg,jpeg,tif,tiff,bmp,webp
INGESTION_DEDUPE_WINDOW_HOURS=24
INGESTION_WORKFLOW_TIMEOUT_MINUTES=30
INGESTION_REQUIRE_AUTH=true
INGESTION_API_KEYS=dev-ingestion-key:default
INGESTION_AUTH_HEADER_NAME=x-api-key
INGESTION_TENANT_HEADER_NAME=x-tenant-id
INGESTION_ACTOR_HEADER_NAME=x-actor-id
INGESTION_DB_POOL_MIN=1
INGESTION_DB_POOL_MAX=5

# API gateway / local load balancer
GATEWAY_HTTP_BIND=0.0.0.0
GATEWAY_HTTP_HOST_PORT=8081
GATEWAY_HTTPS_BIND=0.0.0.0
GATEWAY_HTTPS_HOST_PORT=8443

# Routing + confidence
OCR_CONFIDENCE_THRESHOLD=0.82
VLM_FALLBACK_THRESHOLD=0.80
AUTO_APPROVE_THRESHOLD=0.90
OCR_ENGINE_TIMEOUT_SECONDS=60
OCR_REQUEST_TIMEOUT_SECONDS=90
OCR_MAX_INFLIGHT_REQUESTS=1
OCR_BACKEND=paddle
OCR_FORCE_FALLBACK=false
OCR_TESSERACT_OEM=1
OCR_TESSERACT_PSM=3

# Optional OpenAI-compatible LLM/VLM fallback.
# Apple Silicon local default: keep EXTRACTION_ENABLE_VLM_FALLBACK=false.
# To use Ollama from Docker, set VLLM_BASE_URL=http://host.docker.internal:11434.
# To use LM Studio from Docker, set VLLM_BASE_URL=http://host.docker.internal:1234.
# To use the Docker vllm service, start it explicitly with: docker compose --profile gpu up -d vllm
VLLM_BASE_URL=http://vllm:8000
VLLM_MODEL=vlm-fallback
VLLM_API_KEY=EMPTY
VLLM_MODEL_SOURCE=Qwen/Qwen2.5-VL-7B-Instruct

# Label Studio
LABEL_STUDIO_URL=http://label-studio:8080
LABEL_STUDIO_TOKEN=
LABEL_STUDIO_PROJECT_ID=1
LABEL_STUDIO_USERNAME=reviewer@example.com
LABEL_STUDIO_PASSWORD=replace-with-a-strong-password
LABEL_STUDIO_DISABLE_SIGNUP_WITHOUT_LINK=true
LABEL_STUDIO_ENABLE_LEGACY_API_TOKEN=true
LABEL_STUDIO_AUTH_SCHEME=token

# Human review console
REVIEW_BUCKET=review-artifacts
REVIEW_PROVIDER=auto
REVIEW_REQUEST_TIMEOUT_SECONDS=30
REVIEW_LABEL_STUDIO_TIMEOUT_SECONDS=30
REVIEW_MAX_INFLIGHT_REQUESTS=16
REVIEW_HIGH_PRIORITY_CONFIDENCE_THRESHOLD=0.50
REVIEW_FALLBACK_TO_LOCAL_QUEUE=true
REVIEW_PERSIST_TASKS=true

# Delivery service
DELIVERY_PROVIDERS=object_storage
DELIVERY_REQUIRE_APPROVAL=true
DELIVERY_ALLOWED_APPROVAL_STATUSES=auto_approved,human_approved
DELIVERY_REQUEST_TIMEOUT_SECONDS=60
DELIVERY_MAX_INFLIGHT_REQUESTS=16
DELIVERY_RETRY_MAX=2
DELIVERY_RETRY_BACKOFF_SECONDS=0.5
DELIVERY_PAYLOAD_FORMAT_VERSION=1.0
DELIVERY_REDACT_FIELDS=
# Enables terminal workflow event webhooks when set.
DELIVERY_WEBHOOK_URL=
DELIVERY_WEBHOOK_SECRET=
DELIVERY_WEBHOOK_REQUIRE_SIGNATURE=true
DELIVERY_ALLOW_REQUEST_WEBHOOK_URL=false
DELIVERY_WEBHOOK_ALLOWED_HOSTS=
DELIVERY_WEBHOOK_TIMEOUT_SECONDS=15

# Evaluation service
EVALUATION_BUCKET=evaluation-artifacts
EVALUATION_PROVIDERS=mlflow,artifact_store
EVALUATION_MLFLOW_EXPERIMENT=idp_pipeline
EVALUATION_DATASET_VERSION=production
EVALUATION_PIPELINE_VERSION=development
EVALUATION_REQUEST_TIMEOUT_SECONDS=60
EVALUATION_MAX_INFLIGHT_REQUESTS=16
EVALUATION_RETRY_MAX=1
EVALUATION_RETRY_BACKOFF_SECONDS=0.5
EVALUATION_FAIL_WHEN_ALL_PROVIDERS_FAIL=false

# Workflow metrics
WORKFLOW_METRICS_PORT=9091
WORKFLOW_METRICS_INTERVAL_SECONDS=15

# MLflow
MLFLOW_HOST_PORT=5001
MLFLOW_TRACKING_URI=http://mlflow:5000
AWS_ACCESS_KEY_ID=idpadmin
AWS_SECRET_ACCESS_KEY=idpsecret123
MLFLOW_S3_ENDPOINT_URL=http://seaweedfs:8333

# Grafana
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
PROMETHEUS_BIND=0.0.0.0
PROMETHEUS_HOST_PORT=9090
ALERTMANAGER_BIND=0.0.0.0
ALERTMANAGER_HOST_PORT=9093
GRAFANA_BIND=0.0.0.0
GRAFANA_HOST_PORT=3000

# Alertmanager email delivery
ALERT_EMAIL_TO=basil.sillians@gmail.com
ALERT_EMAIL_FROM=alerts@example.com
ALERT_EMAIL_SMARTHOST=smtp.gmail.com:587
ALERT_EMAIL_USERNAME=alerts@example.com
ALERT_EMAIL_PASSWORD=replace-with-smtp-app-password
ALERT_EMAIL_REQUIRE_TLS=true
ALERT_EMAIL_REPEAT_INTERVAL=4h
